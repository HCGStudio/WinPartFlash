<reactiveui:ReactiveUserControl
    x:TypeArguments="vm:LoggingTabViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:WinPartFlash.Gui.ViewModels"
    xmlns:logging="using:WinPartFlash.Gui.Logging"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lang="clr-namespace:WinPartFlash.Gui.Resources"
    mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="520"
    x:Class="WinPartFlash.Gui.Views.LoggingTabView"
    x:DataType="vm:LoggingTabViewModel"
    xmlns:reactiveui="using:ReactiveUI.Avalonia">

    <StackPanel Margin="0 20 0 0" Spacing="20">

        <StackPanel Spacing="6">
            <TextBlock Classes="SectionLabel" Text="{x:Static lang:Strings.SectionSystemInfo}" />
            <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                  ColumnSpacing="12" RowSpacing="6">
                <Label Grid.Row="0" Grid.Column="0" Content="{x:Static lang:Strings.LabelAppVersion}" />
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Classes="Subtitle" VerticalAlignment="Center"
                           Text="{Binding SystemInfo.AppVersion}" />

                <Label Grid.Row="1" Grid.Column="0" Content="{x:Static lang:Strings.LabelRuntime}" />
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Classes="Subtitle" VerticalAlignment="Center"
                           Text="{Binding SystemInfo.Runtime}" />

                <Label Grid.Row="2" Grid.Column="0" Content="{x:Static lang:Strings.LabelOperatingSystem}" />
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Classes="Subtitle" VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Text="{Binding SystemInfo.OperatingSystem}" />

                <Label Grid.Row="3" Grid.Column="0" Content="{x:Static lang:Strings.LabelNativeLibrary}" />
                <TextBlock Grid.Row="3" Grid.Column="1"
                           Classes="Subtitle" VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Text="{Binding SystemInfo.NativeLibraryStatus}" />

                <Label Grid.Row="4" Grid.Column="0" Content="{x:Static lang:Strings.LabelPrivilegedHelper}" />
                <TextBlock Grid.Row="4" Grid.Column="1"
                           Classes="Subtitle" VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Text="{Binding SystemInfo.PrivilegedHelperStatus}" />
            </Grid>
        </StackPanel>

        <Border Background="{StaticResource LightestGray}" Height="1" />

        <StackPanel Spacing="6">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           Classes="SectionLabel" Text="{x:Static lang:Strings.SectionActivityLog}" />
                <Button Grid.Column="1" Name="CopyLogButton"
                        Content="{x:Static lang:Strings.ButtonCopyLog}"
                        Command="{Binding CopyLogCommand}"
                        CommandParameter="{Binding #CopyLogButton}" />
                <Button Grid.Column="2"
                        Content="{x:Static lang:Strings.ButtonClearLog}"
                        Command="{Binding ClearLogCommand}" />
            </Grid>
            <Border BorderBrush="{StaticResource BorderCool}" BorderThickness="1" CornerRadius="8"
                    Background="{StaticResource Snow}" Height="180" Padding="8">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LogEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="logging:LogEntry">
                                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" FontFamily="{StaticResource MonoFont}"
                                               FontSize="12" Foreground="{StaticResource MutedSlate}"
                                               Text="{Binding Timestamp, StringFormat=HH:mm:ss}" />
                                    <TextBlock Grid.Column="1" FontFamily="{StaticResource MonoFont}"
                                               FontSize="12" Foreground="{StaticResource MutedSlate}"
                                               Text="{Binding Severity}" />
                                    <TextBlock Grid.Column="2" FontSize="12" TextWrapping="Wrap"
                                               Text="{Binding Message}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

    </StackPanel>

</reactiveui:ReactiveUserControl>
